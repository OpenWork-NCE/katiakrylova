{
  "name": "katiakrylova",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "payload": "payload",
    "generate:types": "node --experimental-strip-types --no-warnings scripts/gen-types.mjs",
    "migrate:create": "node --experimental-strip-types --no-warnings scripts/migrate.mjs migrate:create",
    "migrate": "node --experimental-strip-types --no-warnings scripts/migrate.mjs migrate",
    "migrate:status": "node --experimental-strip-types --no-warnings scripts/migrate.mjs migrate:status",
    "migrate:fresh": "node --experimental-strip-types --no-warnings scripts/migrate.mjs migrate:fresh",
    "migrate:content": "node scripts/run-migrate-content.mjs",
    "portfolio:manifest": "node scripts/build-portfolio-manifest.mjs",
    "portfolio:replace": "node scripts/build-portfolio-manifest.mjs && node scripts/run-migrate-content.mjs -- --only=portfolio --replace",
    "patch:migrations": "node scripts/patch-migration-imports.mjs",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.0.0",
    "@payloadcms/next": "^3.0.0",
    "@payloadcms/richtext-lexical": "^3.0.0",
    "@payloadcms/storage-vercel-blob": "^3.0.0",
    "@payloadcms/translations": "^3.85.1",
    "@payloadcms/ui": "^3.0.0",
    "autoprefixer": "^10.5.1",
    "next": "^15.0.0",
    "next-intl": "^4.13.0",
    "payload": "^3.0.0",
    "postcss": "^8.5.15",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.4.19",
    "yet-another-react-lightbox": "^3.32.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^20",
    "@types/react": "^19",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "tsx": "^4.22.4",
    "typescript": "^5"
  },
  "packageManager": "pnpm@11.0.0",
  "engines": {
    "node": ">=20"
  }
}